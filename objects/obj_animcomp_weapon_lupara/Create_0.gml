event_inherited()

// Generated function
// Updates properties of wcomponents
function update_wcomponents() {

	switch (sprite) {
	case spr_lupara_barrel:
		switch (index) {
		case 0:
			new_wcomponents_draw_order("1", "barrel")
			if (ds_map_exists(wcomponents, "barrel")) {with (wcomponents[? "barrel"]) {pos_x=other.pos_x + 11; pos_y=other.pos_y + 0; sprite=undefined; index=0; is_visible=false; pos_rot=other.pos_rot}} break
		case 1:
			new_wcomponents_draw_order("1", "barrel")
