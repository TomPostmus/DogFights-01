			if (ds_map_exists(wcomponents, "barrel")) {with (wcomponents[? "barrel"]) {pos_x=other.pos_x + 11; pos_y=other.pos_y + 0; sprite=undefined; index=0; is_visible=false; pos_rot=other.pos_rot}} break
